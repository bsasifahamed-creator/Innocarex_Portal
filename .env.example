# Copy to .env.local for local development

# PostgreSQL (optional). When set, login uses User table + bcrypt; policies/quotes/contact/docs persist.
# Start DB: from repo root run  docker compose up -d postgres
# Then:  cd innocarex && pnpm db:push && pnpm db:seed
# DATABASE_URL=postgresql://innocarex:innocarex_dev@localhost:5432/innocarex

# JWT signing for portal cookie (use a long random string in production)
SESSION_SECRET=replace-with-at-least-32-random-characters

# Used only when DATABASE_URL is NOT set (demo mode)
DEMO_PORTAL_EMAIL=demo@innocarex.ae
DEMO_PORTAL_PASSWORD=innocarex-demo

# Optional seed overrides when using pnpm db:seed
# SEED_ADMIN_EMAIL=admin@innocarex.ae
# SEED_ADMIN_PASSWORD=admin-innocarex-dev

# Python document-intake service (optional — local OCR runs if unset or on failure)
DOCUMENT_INTAKE_URL=http://127.0.0.1:8080

# Shown on generated e-card / certificate PDFs
DEMO_EMERGENCY_PHONE=+971-4-000-0000

# --- Real-time integrations (SOW M6–M8, M11) — optional; /api/integrations/status checks presence only ---
# ICP_API_BASE_URL=
# ICP_CLIENT_ID=
# ICP_CLIENT_SECRET=
# ICP_WEBHOOK_SECRET=
# INSURER_API_BASE_URL=
# INSURER_API_KEY=
# INSURER_WEBHOOK_SECRET=
# TPA_API_BASE_URL=
# TPA_CLIENT_ID=
# TPA_CLIENT_SECRET=
# PAYMENT_GATEWAY_BASE_URL=
# PAYMENT_GATEWAY_MERCHANT_ID=
# PAYMENT_GATEWAY_API_KEY=
# PAYMENT_WEBHOOK_SECRET=

# Windows: path to tesseract.exe if passport MRZ fails in Python
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
